#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <windows.h>

#define STOCK_COUNT 3

// ================== 변수 ==================
int money = 50000;

int price[STOCK_COUNT]      = {30000, 150000, 400000};
int prev_price[STOCK_COUNT] = {30000, 150000, 400000};

int min_price[STOCK_COUNT]  = {5000,  50000,  180000};
int max_price[STOCK_COUNT]  = {60000, 300000, 800000};

int owned[STOCK_COUNT] = {0, 0, 0};

// -1 하락, 0 변동 X, 1 상승
int last_state[STOCK_COUNT] = {0, 0, 0};

char stock_name[STOCK_COUNT][20] = {
    "Netsla", "Gvidia", "BotCoin"
};

time_t last_update;

// ================== 함수 선언 ==================
void flush_input();
int  update_stock();   // 변동 있으면 1, 없으면 0 반환
void show_stock(int pause_after);
void buy_sell();
void bankrupt();

// ================== 입력 버퍼 비우기 ==================
void flush_input() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

// ================== 주가 변동 ==================
// 반환값: 실제로 변동이 일어났으면 1, 아니면 0
int update_stock() {

    time_t now = time(NULL);
    if (difftime(now, last_update) < 30) return 0;
    last_update = now;

    int changed = 0;

    for (int i = 0; i < STOCK_COUNT; i++) {

        prev_price[i] = price[i];   // 이전 가격 저장

        // 경계에 도달하면 last_state 리셋 후 스킵
        if (price[i] <= min_price[i] || price[i] >= max_price[i]) {
            last_state[i] = 0;
            continue;
        }

        int r = rand() % 10 + 1;
        int dir = 0;

        // 상승 / 하락 확률
        if (last_state[i] == 0) {
            if      (r <= 4) dir =  1;
            else if (r <= 8) dir = -1;
        }
        else if (last_state[i] == 1) {
            if      (r <= 6) dir =  1;
            else if (r <= 9) dir = -1;
        }
        else {
            if      (r <= 3) dir =  1;
            else if (r <= 9) dir = -1;
        }

        // 변동 폭
        int event = rand() % 10 + 1;
        double rate = 0.0;

        if      (event <= 6) rate = (rand() % 5  +  3) / 100.0;
        else if (event <= 9) rate = (rand() % 11 + 10) / 100.0;
        else                 rate = (rand() % 21 + 30) / 100.0;

        if (dir != 0) {
            int diff = (int)(price[i] * rate);
            price[i] += dir * diff;
            last_state[i] = dir;
            changed = 1;
        }
        else {
            last_state[i] = 0;
        }

        if (price[i] < min_price[i]) price[i] = min_price[i];
        if (price[i] > max_price[i]) price[i] = max_price[i];
    }

    return changed;
}

// ================== 주가 보기 ==================
// pause_after: 1이면 마지막에 pause, 0이면 생략
void show_stock(int pause_after) {

    system("cls");

    printf("보유 자금: %d원\n\n", money);

    printf("=======================================================\n");
    printf("|  주종    |    주가   | 변동률(%%) | 보유 수량 |\n");
    printf("=======================================================\n");

    for (int i = 0; i < STOCK_COUNT; i++) {

        double percent = 0.0;
        if (prev_price[i] != 0)
            percent = ((double)(price[i] - prev_price[i]) / prev_price[i]) * 100.0;

        printf("| %-8s | %8d | %+7.2f%% | %8d |\n",
               stock_name[i], price[i], percent, owned[i]);
    }

    printf("=======================================================\n");

    if (pause_after) system("pause");
}

// ================== 구매 / 판매 ==================
void buy_sell() {

    int sel, cnt;

    // 구매/판매 화면에서는 pause 없이 주가만 출력
    show_stock(0);

    printf("\n주식 선택 (1~%d): ", STOCK_COUNT);
    if (scanf("%d", &sel) != 1) { flush_input(); return; }
    flush_input();
    sel--;

    if (sel < 0 || sel >= STOCK_COUNT) {
        printf("잘못된 선택입니다.\n");
        Sleep(1000);
        return;
    }

    printf("수량 입력 (양수=구매 / 음수=판매): ");
    if (scanf("%d", &cnt) != 1) { flush_input(); return; }
    flush_input();

    if (cnt > 0) {

        int cost = cnt * price[sel];

        if (money >= cost) {
            money -= cost;
            owned[sel] += cnt;
            printf("%s %d주 구매 완료!\n", stock_name[sel], cnt);
        }
        else {
            printf("자금 부족! (필요: %d원, 보유: %d원)\n", cost, money);
        }
        Sleep(1200);
    }
    else if (cnt < 0) {

        cnt = -cnt;

        if (owned[sel] >= cnt) {
            owned[sel] -= cnt;
            money += cnt * price[sel];
            printf("%s %d주 판매 완료!\n", stock_name[sel], cnt);
        }
        else {
            printf("보유 수량 부족! (보유: %d주)\n", owned[sel]);
        }
        Sleep(1200);
    }
}

// ================== 파산 ==================
void bankrupt() {

    printf("\n파산했습니다...\n");
    system("pause");
    exit(0);

}

// ================== 메인 ==================
int main() {

    srand((unsigned)time(NULL));
    last_update = time(NULL);

    while (1) {

        // 주가 변동 체크 — 변동 시 메시지 표시
        int stock_changed = update_stock();

        system("cls");

        printf("===== 주식장 =====\n");
        printf("보유 자금: %d원\n\n", money);

        printf("1. 주가 보기\n");
        printf("2. 주식 구매/판매\n");
        printf("3. 파산\n");
        printf("0. 종료\n\n");

        // 주가 변동 알림
        if (stock_changed) {
            printf(">>> 주가 변동!\n");
            Sleep(2000);
            continue;   // Sleep 후 메뉴 다시 그리기
        }

        printf("메뉴 선택: ");
        int menu = -1;
        if (scanf("%d", &menu) != 1) {
            flush_input();
            continue;
        }
        flush_input();

        switch (menu) {
            case 1: show_stock(1); break;
            case 2: buy_sell();    break;
            case 3: bankrupt();    break;
            case 0: return 0;
            default:
                printf("잘못된 입력입니다.\n");
                Sleep(800);
                break;
        }

        // 파산 조건 자동 체크
        if (money <= 0) {
            // 보유 주식이 있으면 전부 강제 청산
            int total_stock_value = 0;
            for (int i = 0; i < STOCK_COUNT; i++)
                total_stock_value += owned[i] * price[i];

            if (total_stock_value == 0) {
                printf("\n잔고와 보유 주식이 모두 없습니다. 파산!\n");
                bankrupt();
            }
        }
    }
}
